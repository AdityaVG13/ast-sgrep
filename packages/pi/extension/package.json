{
  "name": "pi-ast-sgrep",
  "version": "1.1.0-alpha.1",
  "description": "Pi extension for the ast-sgrep native search runtime",
  "type": "module",
  "license": "MIT",
  "keywords": ["pi-package", "ast", "code-search", "semantic-search"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AdityaVG13/ast-sgrep.git",
    "directory": "packages/pi/extension"
  },
  "homepage": "https://github.com/AdityaVG13/ast-sgrep#readme",
  "files": ["dist", "skills", "assets", "LICENSE"],
  "exports": {
    ".": "./dist/index.js",
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    }
  },
  "pi": {
    "extensions": ["./dist/index.js"],
    "skills": ["./skills"],
    "image": "./assets/preview.png"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test test/*.test.ts",
    "prepack": "npm run build"
  },
  "engines": {"node": ">=22.19.0"},
  "dependencies": {"ast-sgrep": "1.1.0-alpha.1", "typebox": "^1.0.0"},
  "peerDependencies": {"@earendil-works/pi-coding-agent": ">=0.80.6 <1"},
  "peerDependenciesMeta": {"@earendil-works/pi-coding-agent": {"optional": true}},
  "devDependencies": {"@earendil-works/pi-coding-agent": "^0.80.6", "@types/node": "^22.15.0", "tsx": "^4.20.0", "typescript": "^5.8.0"}
}
